import sys
import os
import twain
from io import BytesIO
import PIL.Image
from PyQt5.QtWidgets import (QApplication, QMainWindow, QPushButton, QLabel, 
                             QVBoxLayout, QWidget, QFileDialog, QComboBox, 
                             QFormLayout, QHBoxLayout, QMessageBox)
from PyQt5.QtGui import QPixmap, QImage
from PyQt5.QtCore import Qt

class AdvancedTwainScanner(QMainWindow):
    def __init__(self):
        super().__init__()
        self.scanned_image = None  # Holds the PIL Image instance
        self.initUI()
        
    def initUI(self):
        self.setWindowTitle('Advanced PyQt5 TWAIN Scanner')
        self.setGeometry(100, 100, 500, 600)
        
        main_layout = QVBoxLayout()
        form_layout = QFormLayout()
        
        # 1. Color Mode Selection
        self.color_mode_combo = QComboBox()
        self.color_mode_combo.addItems(['Color (RGB)', 'Grayscale', 'Black & White'])
        form_layout.addRow('Color Mode:', self.color_mode_combo)
        
        # 2. Resolution (DPI) Selection
        self.dpi_combo = QComboBox()
        self.dpi_combo.addItems(['150', '200', '300', '600'])
        self.dpi_combo.setCurrentText('300')
        form_layout.addRow('Resolution (DPI):', self.dpi_combo)
        
        # 3. File Format Selection
        self.format_combo = QComboBox()
        self.format_combo.addItems(['PDF', 'TIFF', 'PNG', 'JPEG'])
        form_layout.addRow('Save Format:', self.format_combo)
        
        main_layout.addLayout(form_layout)
        
        # Action Buttons Layout
        btn_layout = QHBoxLayout()
        
        self.scan_button = QPushButton('Scan Document', self)
        self.scan_button.clicked.connect(self.acquire_document)
        btn_layout.addWidget(self.scan_button)
        
        self.save_button = QPushButton('Save Image...', self)
        self.save_button.clicked.connect(self.save_document)
        self.save_button.setEnabled(False)  # Disabled until an image is scanned
        btn_layout.addWidget(self.save_button)
        
        main_layout.addLayout(btn_layout)
        
        # Preview Frame
        self.preview_label = QLabel('Scan a document to view preview', self)
        self.preview_label.setAlignment(Qt.AlignCenter)
        self.preview_label.setStyleSheet("border: 1px dashed #aaa; background-color: #f9f9f9;")
        main_layout.addWidget(self.preview_label, stretch=1)
        
        container = QWidget()
        container.setLayout(main_layout)
        self.setCentralWidget(container)

    def configure_scanner_capabilities(self, source):
        """Negotiates TWAIN capabilities directly with the scanner hardware."""
        # Mapping UI configurations to official TWAIN Constant values
        pixel_type_map = {
            'Color (RGB)': twain.TWPT_RGB,
            'Grayscale': twain.TWPT_GRAY,
            'Black & White': twain.TWPT_BW
        }
        
        selected_mode = self.color_mode_combo.currentText()
        selected_dpi = float(self.dpi_combo.currentText())
        
        try:
            # Set Pixel/Color type (ICAP_PIXELTYPE)
            source.set_capability(
                twain.ICAP_PIXELTYPE, 
                twain.TWTY_UINT16, 
                pixel_type_map[selected_mode]
            )
            
            # Set Resolution across horizontal and vertical metrics (FIX32 Types)
            source.set_capability(twain.ICAP_XRESOLUTION, twain.TWTY_FIX32, selected_dpi)
            source.set_capability(twain.ICAP_YRESOLUTION, twain.TWTY_FIX32, selected_dpi)
            
        except Exception as cap_err:
            # Some drivers throw errors if specific values aren't supported natively
            print(f"Capability negotiation warning: {cap_err}")

    def acquire_document(self):
        try:
            with twain.SourceManager(int(self.winId())) as sm:
                # Prompt user for hardware source
                src = sm.open_source()
                if src:
                    # Negotiate parameters before triggering scan actions
                    self.configure_scanner_capabilities(src)
                    
                    # show_ui=False suppresses the manufacturer's popups 
                    src.request_acquire(show_ui=False, modal_ui=False)
                    
                    # Capture the native DIB image from the driver pipeline
                    rv = src.xfer_image_natively()
                    if rv:
                        handle, remaining = rv
                        bmp_bytes = twain.dib_to_bm_file(handle)
                        
                        # Convert stream data to unified PIL format
                        self.scanned_image = PIL.Image.open(BytesIO(bmp_bytes))
                        
                        # Generate UI visual preview
                        preview_img = self.scanned_image.convert("RGBA")
                        data = preview_img.tobytes("raw", "RGBA")
                        qimage = QImage(data, preview_img.size[0], preview_img.size[1], QImage.Format_RGBA8888)
                        
                        pixmap = QPixmap.fromImage(qimage)
                        self.preview_label.setPixmap(
                            pixmap.scaled(self.preview_label.size(), Qt.KeepAspectRatio, Qt.SmoothTransformation)
                        )
                        
                        self.save_button.setEnabled(True)
                        QMessageBox.information(self, "Success", "Document scanned successfully.")
                        
        except Exception as e:
            QMessageBox.critical(self, "Scanning Error", f"Failed to acquire image: {str(e)}")

    def save_document(self):
        if not self.scanned_image:
            return
            
        selected_format = self.format_combo.currentText()
        
        # Build filter options based on format choices
        file_filter = f"{selected_format} Files (*.{selected_format.lower()})"
        default_name = f"scanned_doc.{selected_format.lower()}"
        
        # Invoke standard native folder/file browser dialog
        file_path, _ = QFileDialog.getSaveFileName(
            self, "Save Scanned Document", default_name, file_filter
        )
        
        if file_path:
            try:
                # Handle special configurations needed for PDF and TIFF compilation
                if selected_format == 'PDF':
                    # PDF conversion requires RGB or Grayscale spaces
                    pdf_ready = self.scanned_image.convert('RGB')
                    pdf_ready.save(file_path, "PDF", resolution=float(self.dpi_combo.currentText()))
                #elif selected_format == 'TIFF':
                    # Save as TIFF utilizing standard LZW compression to prevent bloating sizes
                    #self.scanned_image.save(file_path, "TIFF", compression="tiff_lzw")
                else:
                    self.scanned_image.save(file_path, selected_format)
                    
                QMessageBox.information(self, "Saved", f"File saved successfully to:\n{file_path}")
                
            except Exception as save_err:
                QMessageBox.critical(self, "Save Error", f"Could not save file: {str(save_err)}")

if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = AdvancedTwainScanner()
    ex.show()
    sys.exit(app.exec_())
