lue="79"/><column index="27" value="83"/><column index="28" value="80"/><column index="29" value="89"/><column index="30" value="95"/><column index="31" value="90"/><column index="32" value="104"/><column index="33" value="68"/><column index="34" value="105"/><column index="35" value="129"/><column index="36" value="95"/><column index="37" value="130"/><column index="38" value="89"/><column index="39" value="177"/><column index="40" value="90"/><column index="41" value="87"/><column index="42" value="73"/><column index="43" value="103"/><column index="44" value="74"/><column index="45" value="98"/><column index="46" value="69"/><column index="47" value="97"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">Select i.Line, i.Book, i.Chapter, i.Verse, i.WordNum,a.WordNum, i.Word,a.Word, i.NoDiaWord,a.NoDiaWord, i.Strong,a.Strong, i.RMAC,a.RMAC from TRiWords as i Left Join TRWords as a on i.Line = a.Line and i.WordNum = a.WordNum order by i.Word

</sql><sql name="SQL 4">Select f.ID, f.Line, f.Book, f.Chapter, f.Verse, i.WordNum,f.WordNum, i.Word,f.Word, i.NoDiaWord,f.NoDiaWord, i.Strong,f.Strong, i.RMAC,f.RMAC, i.English, f.English from TRiWords as i Left Join FROMVSWords as f on f.Line == i.Line and f.NoDiaWord == i. NoDiaWord Where f.WordNum IS NOT NULL and f.English &lt;&gt; i.English</sql><sql name="SQL 5">Select f.ID, f.Line, f.Book, f.Chapter, f.Verse, i.WordNum,f.WordNum, i.Word,f.Word, i.NoDiaWord,f.NoDiaWord, i.Strong,f.Strong, i.RMAC,f.RMAC, i.English, f.English from Bible as f Left Join IntBibleWords as i on f.Line == i.Line and f.NoDiaWord == i. NoDiaWord Where f.WordNum == i.WordNum</sql><current_tab id="2"/></tab_sql></sqlb_project>
